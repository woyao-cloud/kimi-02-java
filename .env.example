# =============================================
# User Management System - Environment Variables
# 用户管理系统 - 环境变量配置示例
# =============================================

# =============================================
# Database Configuration
# =============================================
# PostgreSQL 主数据库端口
POSTGRES_PORT=5432

# PostgreSQL 测试数据库端口
POSTGRES_TEST_PORT=5433

# PostgreSQL 密码
POSTGRES_PASSWORD=postgres

# =============================================
# Redis Configuration
# =============================================
# Redis 端口
REDIS_PORT=6379

# Redis 密码 (可选，建议生产环境设置)
REDIS_PASSWORD=

# Redis Commander 端口 (Redis Web UI)
REDIS_COMMANDER_PORT=8081

# =============================================
# pgAdmin Configuration
# =============================================
# pgAdmin 端口
PGADMIN_PORT=5050

# pgAdmin 登录邮箱
PGADMIN_EMAIL=admin@example.com

# pgAdmin 登录密码
PGADMIN_PASSWORD=admin

# =============================================
# Backend Configuration
# =============================================
# 后端服务端口
BACKEND_PORT=8080

# Spring Boot 环境 (dev/prod)
SPRING_PROFILE=dev

# JWT 密钥 (Base64 编码，至少 32 字节)
# 生成命令: openssl rand -base64 32
JWT_SECRET=Y29tcGxleC1zZWNyZXQta2V5LWZvci1qd3Qtc2lnbmluZy1hdC1sZWFzdC0zMmJ5dGVzLWxvbmc=

# =============================================
# Frontend Configuration
# =============================================
# 前端服务端口
FRONTEND_PORT=3000

# =============================================
# Application URLs
# =============================================
# 开发环境 API 地址
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# 生产环境 API 地址 (部署时修改)
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api
